<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android"
        id="cordova-plugin-firebasex-config"
        version="1.0.0">

    <name>cordova-plugin-firebasex-config</name>
    <description>Firebase Remote Config module for cordova-plugin-firebasex</description>
    <license>MIT</license>
    <keywords>cordova,firebase,remote config,config</keywords>

    <engines>
        <engine name="cordova" version=">=12.0.0" />
        <engine name="cordova-android" version=">=14.0.0" />
        <engine name="cordova-ios" version=">=7.0.0" />
    </engines>

    <dependency id="cordova-plugin-firebasex-core" />

    <js-module src="www/firebasex-config.js" name="FirebasexConfigPlugin">
        <clobbers target="FirebasexConfig" />
    </js-module>

    <!-- Android -->
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="FirebasexConfigPlugin">
                <param name="android-package" value="org.apache.cordova.firebasex.FirebasexConfigPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>

        <preference name="ANDROID_FIREBASE_CONFIG_VERSION" default="23.0.1" />

        <framework src="com.google.firebase:firebase-config:$ANDROID_FIREBASE_CONFIG_VERSION" />
        <source-file src="src/android/FirebasexConfigPlugin.java"
                     target-dir="src/org/apache/cordova/firebasex" />
    </platform>

    <!-- iOS -->
    <platform name="ios">
        <config-file target="config.xml" parent="/*">
            <feature name="FirebasexConfigPlugin">
                <param name="ios-package" value="FirebasexConfigPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>

        <header-file src="src/ios/FirebasexConfigPlugin.h" />
        <source-file src="src/ios/FirebasexConfigPlugin.m" />

        <preference name="IOS_FIREBASE_SDK_VERSION" default="12.9.0" />

        <podspec>
            <config>
                <source url="https://cdn.cocoapods.org/" />
            </config>
            <pods use-frameworks="true">
                <pod name="FirebaseRemoteConfig" spec="$IOS_FIREBASE_SDK_VERSION"/>
            </pods>
        </podspec>
    </platform>

</plugin>
